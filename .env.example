# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Database (Prisma)
# ===========================================
# Transaction pooler for runtime (port 6543 + pgbouncer=true)
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
# Direct connection for migrations (port 5432)
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===========================================
# Admin Configuration
# ===========================================
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_DEFAULT_PASSWORD=change-this-immediately
NEXT_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com

# ===========================================
# Cloudflare R2
# ===========================================
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=malazbaca-assets
R2_PUBLIC_URL=https://assets.yourdomain.com

